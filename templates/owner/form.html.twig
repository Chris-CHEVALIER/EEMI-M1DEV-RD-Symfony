{% extends "base.html.twig" %}

{% block body %}
	<h1>Créer un propriétaire</h1>
	{{ form_start(form) }}
	{{ form_row(form.firstName) }}
	{{ form_row(form.lastName) }}
	{{ form_row(form.email) }}
	{{ form_row(form.street) }}
	{{ form_row(form.postalCode) }}
	{{ form_row(form.city) }}
	<input type="submit" class="btn btn-primary mt-2" value="Valider">
	{{ form_end(form) }}
{% endblock %}
