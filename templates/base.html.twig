<!DOCTYPE html>
<html lang="fr-FR">
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Meet My Cat 😼
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>😼</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"/>
		{% block stylesheets %}
			<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		{% endblock %}
	</head>
	<body class="container mt-2">
		<nav class="navbar navbar-expand-lg bg-body-tertiary">
			<div class="container-fluid">
				<a class="navbar-brand" href={{path("home")}}>Meet my Cat</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarNav">
					<ul class="navbar-nav">
						<li class="nav-item">
							<a class="nav-link active" aria-current="page" href={{path("home")}}>Accueil</a>
						</li>
						{% if is_granted("IS_AUTHENTICATED_FULLY") %}
							<li class="nav-item">
								<a class="nav-link" href={{path("create_owner")}}>Ajouter un propriétaire</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href={{path("create_cat")}}>Ajouter un chat</a>
							</li>
						{% endif %}
					</ul>
				</div>
				{% if is_granted("IS_AUTHENTICATED_FULLY") %}
					<a class="nav-link" href={{path("logout")}}>Se déconnecter</a>
				{% else %}
					<a class="nav-link" href={{path("login")}}>Se connecter</a>
					/
					<a class="nav-link" href={{path("register")}}>S'enregistrer</a>
				{% endif %}
			</div>
		</nav>
		{% block body %}{% endblock %}

		{% block javascripts %}
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		{% endblock %}
	</body>
</html>
